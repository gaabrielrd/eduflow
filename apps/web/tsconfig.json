{
  "extends": "@eduflow/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "jsx": "react-jsx",
    "paths": {
      "@eduflow/types": [
        "../../../packages/types/src/index.ts"
      ],
      "@eduflow/types/*": [
        "../../../packages/types/src/*"
      ],
      "@eduflow/ui": [
        "../../../packages/ui/src/index.ts"
      ],
      "@eduflow/ui/*": [
        "../../../packages/ui/src/*"
      ],
      "@hookform/resolvers/zod": [
        "../node_modules/@hookform/resolvers/zod"
      ],
      "@testing-library/jest-dom/vitest": [
        "../node_modules/@testing-library/jest-dom/vitest"
      ],
      "@testing-library/react": [
        "../node_modules/@testing-library/react"
      ],
      "@testing-library/user-event": [
        "../node_modules/@testing-library/user-event"
      ],
      "@/*": [
        "./*"
      ],
      "react-hook-form": [
        "../node_modules/react-hook-form"
      ],
      "vitest": [
        "../node_modules/vitest"
      ],
      "vitest/*": [
        "../node_modules/vitest/*"
      ],
      "zod": [
        "../node_modules/zod"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    ".next/types/**/*.ts",
    "../../packages/types/src/**/*.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**"
  ]
}
