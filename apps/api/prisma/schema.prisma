generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  INSTRUCTOR
  MANAGER
  STUDENT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonContentType {
  TEXT
  VIDEO
  QUIZ
  FILE
}

enum CourseModuleStatus {
  ACTIVE
  ARCHIVED
}

enum LessonStatus {
  ACTIVE
  ARCHIVED
}

enum MediaAssetStatus {
  PENDING
  READY
  FAILED
  DELETED
}

model User {
  id                 String       @id @default(cuid())
  name               String
  email              String       @unique
  passwordHash       String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  authSessions       AuthSession[]
  memberships        Membership[]
  createdCourses     Course[]     @relation("CourseCreatedBy")
  uploadedMediaAssets MediaAsset[] @relation("MediaAssetUploadedBy")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  invitations Invitation[]
  courses     Course[]
  mediaAssets MediaAsset[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  role           Role
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId])
  @@index([organizationId, email])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([revokedAt])
}

model Course {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  slug           String
  description    String?
  status         CourseStatus
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy      User         @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  modules        CourseModule[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdById])
}

model CourseModule {
  id          String             @id @default(cuid())
  courseId    String
  title       String
  description String?
  position    Int
  status      CourseModuleStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lessons     Lesson[]

  @@unique([courseId, position])
  @@index([courseId])
}

model Lesson {
  id                       String            @id @default(cuid())
  moduleId                 String
  title                    String
  description              String?
  contentType              LessonContentType
  contentJson              Json
  position                 Int
  estimatedDurationMinutes Int?
  isPreview                Boolean           @default(false)
  status                   LessonStatus      @default(ACTIVE)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  module                   CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([moduleId, position])
  @@index([moduleId])
}

model MediaAsset {
  id             String           @id @default(cuid())
  organizationId String
  uploadedById   String
  fileName       String
  originalName   String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  status         MediaAssetStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  uploadedBy     User             @relation("MediaAssetUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([organizationId])
  @@index([uploadedById])
  @@index([status])
  @@index([organizationId, status])
}
